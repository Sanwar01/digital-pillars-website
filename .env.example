# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Where enquiry emails are delivered (defaults to SITE.email)
ENQUIRY_TO_EMAIL=hello@digitalpillars.co.uk

# Verified Resend sender. Until your domain is verified in Resend,
# you can use the shared testing sender: onboarding@resend.dev
ENQUIRY_FROM_EMAIL="Digital Pillars <onboarding@resend.dev>"

# Google Search Console — HTML tag verification token (meta content value).
# Add after the domain is live: Search Console → Settings → Ownership verification → HTML tag.
# GOOGLE_SITE_VERIFICATION=your-verification-token
GOOGLE_SITE_VERIFICATION=I1gGRYjIIpWiJ0iMzI4gggJIthfz9g8CsOHIGqX0WTA

# Google Analytics 4 — Measurement ID (Admin → Data streams → Web → Measurement ID)
# Example: G-XXXXXXXXXX
# NEXT_PUBLIC_ prefix is required so the browser can load the tag.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-56Z8DXDPH2
